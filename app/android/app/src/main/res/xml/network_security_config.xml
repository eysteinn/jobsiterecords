<?xml version="1.0" encoding="utf-8"?>
<!-- Allows HTTP to local Docker / LAN dev API. Production builds use HTTPS API_BASE_URL. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
