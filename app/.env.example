# Symlink to repo root .env (recommended):
#   ln -s ../.env app/.env
#
# Or copy this file to app/.env and fill in values.
# See ../.env.example for the full local dev template (API, MinIO, Maps).

GOOGLE_MAPS=

# Google OAuth — use the Web application client ID (not the comma-separated API list).
# Prefer GOOGLE_WEB_CLIENT_ID; otherwise the first value in GOOGLE_CLIENT_ID is used.
GOOGLE_WEB_CLIENT_ID=
# Optional fallback if you only set one var (Web client ID must be first if comma-separated).
GOOGLE_CLIENT_ID=

API_BASE_URL=http://10.0.0.3:8080
