# Symlink to repo root .env (recommended):
#   ln -s ../.env app/.env
#
# Or copy this file to app/.env and fill in values.
# See ../.env.example for the full local dev template (API, MinIO, Maps).

GOOGLE_MAPS=

# Google OAuth Web client ID — used as serverClientId on Android for ID token aud.
# Must be listed in API GOOGLE_CLIENT_ID. Hidden on iOS until Sign in with Apple ships.
GOOGLE_CLIENT_ID=

API_BASE_URL=http://10.0.0.3:8080
