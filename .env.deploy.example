# Copy to .env.deploy on the server and fill in secrets before first boot:
#   cp .env.deploy.example .env.deploy

# --- Domains (DNS must point at the Traefik host) ---
# Use A records for app/api/media to the VPS IP — do not CNAME api/media to the apex
# if the marketing site lives elsewhere (stale CNAME → wrong TLS / 1984 cert).
APP_HOST=app.jobsiterecords.com
API_HOST=api.jobsiterecords.com
MEDIA_HOST=media.jobsiterecords.com

# --- Traefik (must match your existing Traefik static/dynamic config) ---
# Docker network Traefik is attached to (docker network ls).
# On a shared host with Aldadrift etc., use the existing external network name:
TRAEFIK_NETWORK=traefik_reverse_proxy
# HTTPS entrypoint name from traefik.yml
TRAEFIK_ENTRYPOINT=websecure
# Certificate resolver name from traefik.yml (omit tls label in compose if you terminate TLS elsewhere)
TRAEFIK_CERT_RESOLVER=letsencrypt

# --- Postgres ---
POSTGRES_USER=jobsiterecords
POSTGRES_PASSWORD=change-me
POSTGRES_DB=jobsiterecords

# --- MinIO / S3 ---
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
S3_BUCKET=jobsiterecords
# Public URL MinIO advertises behind Traefik (must match MEDIA_HOST)
MINIO_SERVER_URL=https://media.jobsiterecords.com

# --- API secrets & URLs ---
JWT_SECRET=change-me-long-random-string
APP_URL=https://app.jobsiterecords.com
CORS_ORIGINS=https://app.jobsiterecords.com

# --- Google OAuth ---
# Comma-separated client IDs whose token aud the API accepts (Web + Android + iOS).
GOOGLE_CLIENT_ID=
# Web application client secret (Next.js BFF only — not on API or Flutter).
GOOGLE_CLIENT_SECRET=

# --- Web (NEXT_PUBLIC_* vars are baked in at image build time) ---
NEXT_PUBLIC_API_URL=https://api.jobsiterecords.com
# Browser-restricted Places key for job address autocomplete (HTTP referrer = APP_HOST).
NEXT_PUBLIC_GOOGLE_MAPS=

# --- Paddle Billing ---
NEXT_PUBLIC_PADDLE_ENV=production
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_PRICE_ID_SOLO_1_MONTHLY=
NEXT_PUBLIC_PADDLE_PRICE_ID_CREW_5_MONTHLY=
NEXT_PUBLIC_PADDLE_PRICE_ID_TEAM_15_MONTHLY=

PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENV=production
PADDLE_PRICE_ID_SOLO_1_MONTHLY=
PADDLE_PRICE_ID_CREW_5_MONTHLY=
PADDLE_PRICE_ID_TEAM_15_MONTHLY=

# --- Outbound email (worker sends via SMTP; API enqueues River jobs) ---
SMTP_HOST=mail.1984.is
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Job Site Records

# --- River workers (production uses split mail + reports services) ---
# Scale mail workers: docker compose ... up -d --scale worker-mail=2 worker-mail worker-reports
WORKER_MAIL_CONCURRENCY=5
WORKER_REPORTS_CONCURRENCY=5
