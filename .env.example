# Local dev secrets — copy to `.env` at repo root.
# Flutter loads this via `app/.env` → symlink to `../.env` (see app/README.md).
# Docker Compose reads the same file for ${VAR} substitution in docker-compose.yml.

# Google Maps / Places API key.
# Mobile (Flutter): Android app restriction com.jobsiterecords.app — see app/README.md.
# Web dashboard: use a separate browser key with HTTP referrer restriction for your app origin.
GOOGLE_MAPS=
NEXT_PUBLIC_GOOGLE_MAPS=

# Google OAuth — API: comma-separated client IDs allowed in ID token aud (Web first).
# Web BFF: uses GOOGLE_WEB_CLIENT_ID if set, else the first ID in GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LAN IP or hostname your phone can reach (not localhost). Run `hostname -I` on the dev machine.
DEV_LAN_HOST=10.0.0.3

# Flutter → API (use DEV_LAN_HOST when testing on a physical device).
API_BASE_URL=http://10.0.0.3:8080

# MinIO presigned URLs for blob upload from phone (host:port, no scheme).
# Must match DEV_LAN_HOST; Docker internal S3_ENDPOINT stays minio:9000.
S3_PUBLIC_ENDPOINT=10.0.0.3:9000
